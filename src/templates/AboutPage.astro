---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations, type Lang, type TranslationKey } from '../i18n/ui';
import { COMPANY } from '../constants';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const base = lang === 'en' ? '/en' : '';
---

<BaseLayout
  title={t('meta.about.title')}
  description={t('meta.about.desc')}
  lang={lang}
  canonicalPath={lang === 'en' ? '/en/about' : '/about'}
>

  <section class="page-hero section--dark section--centered">
    <div class="container--narrow">
      <div class="gold-rule"></div>
      <p class="section-label">{t('about.page.label')}</p>
      <h1 class="section-title">
        {t('about.page.title')}<br /><em>{t('about.page.title.em')}</em>
      </h1>
      <p class="section-body page-hero-body">{t('about.page.subtitle')}</p>
    </div>
  </section>

  <section class="section story-section">
    <div class="container story-grid">
      <div class="story-text">
        <div class="gold-rule"></div>
        <p class="section-label">{t('about.story.label')}</p>
        <h2 class="section-title">{t('about.story.title')}</h2>
        <p class="section-body">{t('about.story.body1')}</p>
        <p class="section-body story-body-2">{t('about.story.body2')}</p>
      </div>
      <div class="story-image-placeholder" aria-hidden="true">
        <div class="story-year-overlay">
          <span>Est.</span>
          <strong>1968</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--cream section--centered">
    <div class="container--narrow">
      <div class="gold-rule"></div>
      <p class="section-label">{t('values.label')}</p>
      <h2 class="section-title">{t('values.title')}</h2>
    </div>
    <div class="container values-grid">
      {[1,2,3,4].map(n => (
        <div class="value-card">
          <div class="value-rule"></div>
          <h3 class="value-title">{t(`value.${n}.title`  as TranslationKey)}</h3>
          <p class="value-body">{t(`value.${n}.body`  as TranslationKey)}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="section section--dark">
    <div class="container locations-grid">
      <div>
        <div class="gold-rule"></div>
        <p class="section-label">{t('locations.label')}</p>
        <h2 class="section-title">{t('locations.title')}</h2>
        <p class="section-body">{t('locations.body')}</p>
        <a href={`${base}/contact`} class="btn btn--gold locations-cta">{t('locations.cta')}</a>
      </div>
      <div class="location-cards">
        <div class="location-card">
          <p class="location-card-label">{t('location.mykonos')}</p>
          <p class="location-card-address">{COMPANY.location.display}, {COMPANY.location.country}</p>
          <p class="location-card-phone">
            <a href={COMPANY.phone.href}>{COMPANY.phone.display}</a>
          </p>
          <p class="location-hours">{t('footer.hours.weekday')} · {t('footer.hours.sunday')}</p>
        </div>
        <div class="location-card">
          <p class="location-card-label">{t('location.athens')}</p>
          <p class="location-card-address">Athens, Greece</p>
          <p class="location-hours">{t('location.call')}</p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.page-hero { padding-block: var(--space-20); }
.page-hero-body { margin-inline: auto; }
.page-hero .section-title em { font-style: italic; color: var(--color-gold); }

.story-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-16);
  align-items: center;
}
.story-body-2 { margin-top: var(--space-4); }
.story-image-placeholder {
  position: relative;
  aspect-ratio: 4/5;
  background: linear-gradient(135deg, var(--color-dark) 0%, var(--color-dark-warm) 100%);
  border-radius: var(--radius-md);
  border: 1px solid rgba(201,169,110,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}
.story-year-overlay {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: var(--color-gold);
  opacity: 0.25;
}
.story-year-overlay span {
  font-size: var(--text-sm);
  letter-spacing: 0.2em;
  text-transform: uppercase;
}
.story-year-overlay strong {
  font-family: var(--font-heading);
  font-size: 5rem;
  font-weight: 700;
  line-height: 1;
}

.values-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-8);
  margin-top: var(--space-12);
}
.value-card { padding-top: var(--space-2); }
.value-rule {
  width: 32px;
  height: 2px;
  background-color: var(--color-gold);
  margin-bottom: var(--space-4);
}
.value-title {
  font-family: var(--font-heading);
  font-size: var(--text-xl);
  font-weight: 600;
  margin-bottom: var(--space-3);
}
.value-body {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  line-height: 1.7;
}

.locations-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-16);
  align-items: start;
}
.locations-cta { margin-top: var(--space-8); }
.location-cards { display: flex; flex-direction: column; gap: var(--space-6); }
.location-card {
  padding: var(--space-8);
  border: 1px solid rgba(201,169,110,0.2);
  border-radius: var(--radius-md);
}
.location-card-label {
  font-size: var(--text-xs);
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--color-gold);
  margin-bottom: var(--space-2);
}
.location-card-address { font-size: var(--text-base); color: var(--color-cream); margin-bottom: var(--space-2); }
.location-card-phone a { color: var(--color-gold); transition: color var(--transition-fast); }
.location-card-phone a:hover { color: var(--color-gold-light); }
.location-hours { font-size: var(--text-sm); color: var(--color-text-muted); margin-top: var(--space-2); }

@media (max-width: 900px) {
  .story-grid { grid-template-columns: 1fr; }
  .story-image-placeholder { display: none; }
  .values-grid { grid-template-columns: 1fr 1fr; }
  .locations-grid { grid-template-columns: 1fr; }
}
@media (max-width: 640px) {
  .values-grid { grid-template-columns: 1fr; }
}
</style>
