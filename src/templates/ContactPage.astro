---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations, type Lang } from '../i18n/ui';
import { COMPANY } from '../constants';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<BaseLayout
  title={t('meta.contact.title')}
  description={t('meta.contact.desc')}
  lang={lang}
  canonicalPath={lang === 'en' ? '/en/contact' : '/contact'}
>

  <section class="page-hero section--dark section--centered">
    <div class="container--narrow">
      <div class="gold-rule"></div>
      <p class="section-label">{t('contact.page.label')}</p>
      <h1 class="section-title">{t('contact.page.title')}</h1>
      <p class="section-body page-hero-body">{t('contact.page.subtitle')}</p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <div class="contact-info">
        <div class="gold-rule"></div>
        <h2 class="section-title contact-title">{t('contact.store.title')}</h2>

        <div class="info-block">
          <p class="info-label">{t('contact.address.label')}</p>
          <p class="info-value">{COMPANY.location.display}</p>
          <p class="info-value">{COMPANY.location.country}</p>
        </div>

        <div class="info-block">
          <p class="info-label">{t('contact.phone.label')}</p>
          <a href={COMPANY.phone.href} class="info-value info-link">{COMPANY.phone.display}</a>
        </div>

        <div class="info-block">
          <p class="info-label">{t('contact.hours.label')}</p>
          <p class="info-value">{t('footer.hours.weekday')}</p>
          <p class="info-value">{t('footer.hours.sunday')}</p>
        </div>

        <div class="info-block">
          <p class="info-label">{t('contact.instagram.label')}</p>
          <a
            href={COMPANY.instagram.url}
            target="_blank"
            rel="noopener noreferrer"
            class="info-value info-link"
          >
            {COMPANY.instagram.handle}
          </a>
        </div>
      </div>

      <div class="contact-form-wrap">
        <form
          class="contact-form"
          name="contact"
          method="POST"
          action="/thank-you"
          data-netlify="true"
          novalidate
        >
          <input type="hidden" name="form-name" value="contact" />

          <div class="form-row">
            <label for="name" class="form-label">{t('contact.form.name')}</label>
            <input type="text" id="name" name="name" class="form-input"
              placeholder={t('contact.form.name.ph')} required />
          </div>

          <div class="form-row">
            <label for="phone" class="form-label">{t('contact.form.phone')}</label>
            <input type="tel" id="phone" name="phone" class="form-input" placeholder="+30 ..." />
          </div>

          <div class="form-row">
            <label for="email" class="form-label">{t('contact.form.email')}</label>
            <input type="email" id="email" name="email" class="form-input"
              placeholder="your@email.com" required />
          </div>

          <div class="form-row">
            <label for="service" class="form-label">{t('contact.form.service')}</label>
            <select id="service" name="service" class="form-input form-select">
              <option value="">{t('contact.form.service.ph')}</option>
              <option value="dry-cleaning">{t('contact.service.dry')}</option>
              <option value="laundry">{t('contact.service.laundry')}</option>
              <option value="home-textiles">{t('contact.service.home')}</option>
              <option value="hotel">{t('contact.service.hotel')}</option>
              <option value="other">{t('contact.service.other')}</option>
            </select>
          </div>

          <div class="form-row">
            <label for="message" class="form-label">{t('contact.form.message')}</label>
            <textarea id="message" name="message" class="form-input form-textarea"
              placeholder={t('contact.form.message.ph')} rows="5"></textarea>
          </div>

          <button type="submit" class="btn btn--gold form-submit">
            {t('contact.form.submit')}
          </button>
        </form>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.page-hero { padding-block: var(--space-20); }
.page-hero-body { margin-inline: auto; }

.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-16);
  align-items: start;
}
.contact-title { font-size: var(--text-3xl); }

.info-block { margin-bottom: var(--space-8); }
.info-label {
  font-size: var(--text-xs);
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--color-gold);
  margin-bottom: var(--space-2);
}
.info-value { font-size: var(--text-base); color: var(--color-text-dark); line-height: 1.8; }
.info-link { display: inline-block; color: var(--color-text-dark); transition: color var(--transition-fast); }
.info-link:hover { color: var(--color-gold); }

.contact-form { display: flex; flex-direction: column; gap: var(--space-6); }
.form-row { display: flex; flex-direction: column; gap: var(--space-2); }
.form-label {
  font-size: var(--text-xs);
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-text-muted);
}
.form-input {
  font-family: var(--font-body);
  font-size: var(--text-base);
  color: var(--color-text-dark);
  background-color: var(--color-white);
  border: 1px solid rgba(0,0,0,0.15);
  border-radius: var(--radius-sm);
  padding: var(--space-4);
  transition: border-color var(--transition-fast);
  outline: none;
  width: 100%;
}
.form-input:focus { border-color: var(--color-gold); }
.form-textarea { resize: vertical; min-height: 130px; }
.form-select { appearance: none; cursor: pointer; }
.form-submit { align-self: flex-start; }

@media (max-width: 900px) {
  .contact-grid { grid-template-columns: 1fr; }
}
</style>
